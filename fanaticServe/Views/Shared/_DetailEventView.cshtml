@model fanaticServe.Core.Dto.DetailEvent

<div class="card">
    <div class="card-header">
        <div class="row">
            <div class="col-sm-5">
                @Html.DisplayNameFor(modelItem => Model.Place):@Html.DisplayFor(modelItem => Model.Place)
            </div>
            <div class="col-sm-5">
                @Html.DisplayNameFor(modelItem => Model.Perform_at):@Html.DisplayFor(modelItem => Model.Perform_at)
            </div>
        </div>
    </div>
    <div class="card-body">
        @if (!String.IsNullOrEmpty(Model.Note))
        {
            <div class="row">
                <div class="col-sm-12">@Model.Note</div>
            </div>
        }
        @await Html.PartialAsync("_SetListsView", Model.SetLists)
    </div>
</div>

@if (Model.LiveEventUrls != null && Model.LiveEventUrls.Count() > 0)
{
    var accId = $"acc-id-{Model.Live_event_id}";
    <div class="accordion">
        <div class="accordion-item">
            <h3 class="accordion-header">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#@accId" aria-expanded="true" aria-controls="@accId">
                    関連
                </button>
            </h3>
            @foreach (var leUrl in Model.LiveEventUrls)
            {
                string targetString;
                if (string.IsNullOrEmpty(leUrl.Description))
                {
                    targetString = leUrl.Url ?? "";
                }
                else
                {
                    targetString = leUrl.Description;
                }

                <div id="@accId" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <a href="@leUrl.Url">@Html.Display(targetString )</a>
                        てす3
                    </div>
                </div>
            }
        </div>
    </div>
}